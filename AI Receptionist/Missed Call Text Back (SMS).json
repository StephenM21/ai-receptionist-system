    {
      "parameters": {
        "jsCode": "const payload = $json.body || {};\nconst from = String(payload.From ?? $json.From ?? \"\").trim();\nconst to = String(payload.To ?? $json.To ?? \"\").trim();\n\nconst smsReply =\n  \"Sorry we missed your call. You can reply here with what you need, and our team will follow up as soon as possible.\";\n\nconst twiml =\n  '<?xml version=\"1.0\" encoding=\"UTF-8\"?>' +\n  '<Response>' +\n  '<Say>Sorry we missed your call. Please send us a text with what you need, and our team will follow up shortly.</Say>' +\n  '<Hangup/>' +\n  '</Response>';\n\nreturn [\n  {\n    json: {\n      from,\n      to,\n      smsReply,\n      twiml,\n    },\n  },\n];"
      },
